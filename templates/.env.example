# =============================================================================
# publish-from-notion — Environment Configuration
# =============================================================================
# Copy this file to your project root as .env:
#   cp templates/.env.example .env
#
# Uncomment only the platforms you use. Leave the rest commented out.
# See docs/api-setup.md for step-by-step instructions to get each token.
# =============================================================================


# === NOTION (required) ========================================================
# Your Notion integration token and database IDs.
# Create an integration at: https://www.notion.so/my-integrations
# Share your databases with the integration after creating it.

NOTION_TOKEN=secret_...
NOTION_DB_ARTICLES=                         # Central Articles database ID


# === GHOST (recommended — primary publication platform) =======================
# Your Ghost blog. Content from Notion is pushed directly to Ghost.
# Get your Admin API Key: Ghost Admin → Settings → Integrations → Add custom
# Format: {key_id}:{key_secret}

# GHOST_API_URL=https://your-site.ghost.io
# GHOST_ADMIN_KEY=
# NOTION_DB_GHOST=                          # Ghost drafts database ID (optional)


# === LINKEDIN (optional — social distribution) ================================
# Post to LinkedIn as yourself or as a company page.
# Create an app: https://developer.linkedin.com/
# Required: Company Page association + "Share on LinkedIn" product
# Scope: w_member_social
# Note: OAuth token expires after 60 days — plan for renewal.

# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_PERSON_URN=urn:li:person:XXXXXXX
# NOTION_DB_LINKEDIN=                       # LinkedIn posts database ID


# === TWITTER / X (optional — social distribution) ============================
# Post tweets with links to your Ghost articles.
# Create an app: https://developer.twitter.com/
# Free tier: up to 1,500 tweets/month
# IMPORTANT: Set "Read and Write" permissions BEFORE generating tokens.

# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# NOTION_DB_TWITTER=                        # Twitter posts database ID


# === FACEBOOK (optional — social distribution) ================================
# Post to a Facebook Page (not personal profile).
# Create an app: https://developers.facebook.com/ → Business type
# Generate a Page Access Token (not User Token) with long-lived expiry.
# Scopes: pages_manage_posts, pages_read_engagement

# FACEBOOK_PAGE_ID=
# FACEBOOK_ACCESS_TOKEN=
# NOTION_DB_FACEBOOK=                       # Facebook posts database ID


# === MASTODON (optional — social distribution) ================================
# Post to any Mastodon instance.
# Create an app: Your Instance → Preferences → Development → New Application
# Redirect URI: urn:ietf:wg:oauth:2.0:oob
# Scopes: read, write:statuses

# MASTODON_INSTANCE_URL=https://mastodon.social
# MASTODON_ACCESS_TOKEN=
# NOTION_DB_MASTODON=                       # Mastodon posts database ID


# === BLUESKY (optional — social distribution) =================================
# Post to Bluesky via AT Protocol.
# Create an App Password: Settings → App Passwords → Add App Password
# Use an App Password, NOT your account password.

# BLUESKY_HANDLE=your-handle.bsky.social
# BLUESKY_APP_PASSWORD=
# NOTION_DB_BLUESKY=                        # Bluesky posts database ID


# === SCHEDULING ===============================================================
# Which platform sets the master schedule. All other platforms are offset
# relative to this. Default: linkedin
# Options: ghost, linkedin, twitter, facebook, mastodon, bluesky

# MASTER_CLOCK_PLATFORM=linkedin
# TIMEZONE=Europe/Brussels
